# The showcase queries the Verana Trust Resolver and the chain indexer directly from
# the browser (their CORS is open), so most of it needs no configuration.
#
# The live credential issuance flow (#26) is the exception: the server runs the eSignet
# authorization-code flow with a dedicated OIDC client, so it needs that client's
# private key. Generate a keypair, register the public key as an eSignet client
# (esignet-vs/clients/playground.json), and keep the matching private JWK below, in
# .env.local, which is gitignored and never committed.
PLAYGROUND_OIDC_CLIENT_ID=mosip-playground
PLAYGROUND_OIDC_PRIVATE_JWK={"kty":"RSA","kid":"...","alg":"RS256","use":"sig","n":"...","e":"AQAB","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"..."}
