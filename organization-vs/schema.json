{
  "$id": "https://verana-labs.github.io/verifiable-trust-spec/schemas/v4/foundational-resident-id.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Foundational Resident ID Credential",
  "description": "A foundational resident identity credential issued under the MOSIP Pilot Authority trust ecosystem on the Verana Trust Network.",
  "type": "object",
  "properties": {
    "credentialSubject": {
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "dateOfBirth": {
          "type": "string",
          "format": "date"
        },
        "gender": {
          "type": "string",
          "enum": ["male", "female", "other", "unspecified"]
        },
        "nationality": {
          "type": "string",
          "minLength": 2,
          "maxLength": 64
        },
        "residentAddress": {
          "type": "string",
          "maxLength": 512
        },
        "identifier": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        }
      },
      "required": ["fullName", "dateOfBirth", "identifier"]
    }
  }
}
